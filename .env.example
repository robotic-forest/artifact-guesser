# MongoDB
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DATABASE="staging"  # "production" for prod, "staging" for dev, tests use MongoMemoryServer

# Auth
SESSION_PASSWORD="at-least-32-characters-long-password-here"
SECRET="jwt-signing-secret"

# Stripe
STRIPE_LIVE_SECRET_KEY="sk_live_..."  # or sk_test_... for test mode

# Email (Mailjet)
MAILJET_USER=""
MAILJET_PASSWORD=""

# Domain
DOMAIN="http://localhost:5000"

# Socket.IO — defaults to http://localhost:9667 if unset.
# Point at the hosted mainframe when not working on protocodex-mainframe locally:
NEXT_PUBLIC_SOCKET_URL="https://api.protocodex.com"
# NEXT_PUBLIC_SOCKET_URL="http://localhost:9667"

# GoatCounter (legacy, being replaced)
# GOATCOUNTER_TOKEN=""
